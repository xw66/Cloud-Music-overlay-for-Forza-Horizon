<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Color x:Key="MaterialPrimaryColor">#5B5CEB</Color>
    <Color x:Key="MaterialPrimaryDarkColor">#20263A</Color>
    <Color x:Key="MaterialBackgroundColor">#F5F7FB</Color>
    <Color x:Key="MaterialSurfaceColor">#FFFFFF</Color>
    <Color x:Key="MaterialBorderColor">#E2E8F0</Color>
    <Color x:Key="MaterialTextColor">#18212F</Color>
    <Color x:Key="MaterialSubtleTextColor">#64748B</Color>
    <Color x:Key="MaterialDangerColor">#E0565B</Color>
    <Color x:Key="MaterialSuccessColor">#22C55E</Color>

    <SolidColorBrush x:Key="PrimaryBrush" Color="{StaticResource MaterialPrimaryColor}" />
    <SolidColorBrush x:Key="PrimaryDarkBrush" Color="{StaticResource MaterialPrimaryDarkColor}" />
    <SolidColorBrush x:Key="BackgroundBrush" Color="{StaticResource MaterialBackgroundColor}" />
    <SolidColorBrush x:Key="SurfaceBrush" Color="{StaticResource MaterialSurfaceColor}" />
    <SolidColorBrush x:Key="BorderBrush" Color="{StaticResource MaterialBorderColor}" />
    <SolidColorBrush x:Key="TextBrush" Color="{StaticResource MaterialTextColor}" />
    <SolidColorBrush x:Key="SubtleTextBrush" Color="{StaticResource MaterialSubtleTextColor}" />
    <SolidColorBrush x:Key="DangerBrush" Color="{StaticResource MaterialDangerColor}" />
    <SolidColorBrush x:Key="SuccessBrush" Color="{StaticResource MaterialSuccessColor}" />

    <Style TargetType="Window">
        <Setter Property="Background" Value="{StaticResource BackgroundBrush}" />
        <Setter Property="Foreground" Value="{StaticResource TextBrush}" />
        <Setter Property="FontFamily" Value="pack://application:,,,/Assets/Fonts/#MiSans Demibold" />
    </Style>

    <Style x:Key="PageTitleTextStyle" TargetType="TextBlock">
        <Setter Property="FontSize" Value="28" />
        <Setter Property="FontWeight" Value="SemiBold" />
        <Setter Property="Foreground" Value="{StaticResource TextBrush}" />
    </Style>

    <Style x:Key="SectionTitleTextStyle" TargetType="TextBlock">
        <Setter Property="FontSize" Value="17" />
        <Setter Property="FontWeight" Value="SemiBold" />
        <Setter Property="Foreground" Value="{StaticResource TextBrush}" />
    </Style>

    <Style x:Key="BodyTextStyle" TargetType="TextBlock">
        <Setter Property="Foreground" Value="{StaticResource SubtleTextBrush}" />
        <Setter Property="FontSize" Value="13" />
        <Setter Property="TextWrapping" Value="Wrap" />
    </Style>
</ResourceDictionary>
