<Window x:Class="HorizonRadioOverlay.OverlayWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Overlay"
        Width="210"
        Height="198"
        WindowStyle="None"
        ResizeMode="NoResize"
        AllowsTransparency="True"
        Background="Transparent"
        ShowInTaskbar="False"
        ShowActivated="False"
        Topmost="True"
        Focusable="False"
        FontFamily="pack://application:,,,/Assets/Fonts/#MiSans Demibold">
    <Window.Resources>
        <DropShadowEffect x:Key="TextGlow" Color="#0B1017" BlurRadius="14" ShadowDepth="0" Opacity="0.95" />
        <DropShadowEffect x:Key="CoverShadow" Color="#091019" BlurRadius="18" ShadowDepth="4" Direction="270" Opacity="0.55" />
        <LinearGradientBrush x:Key="InfoGlow" StartPoint="0,0" EndPoint="0,1">
            <GradientStop Color="#1A273545" Offset="0" />
            <GradientStop Color="#00273545" Offset="1" />
        </LinearGradientBrush>
    </Window.Resources>

    <Viewbox Stretch="Fill">
        <Grid Name="OverlayRoot" Width="210" Height="198" Background="Transparent" Margin="0" Opacity="0">
            <Grid.RenderTransform>
                <TranslateTransform x:Name="RootTransform" Y="8" />
            </Grid.RenderTransform>

            <Grid.RowDefinitions>
                <RowDefinition x:Name="CoverRow" Height="106" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>

            <Viewport3D Name="CoverFlowViewport"
                        Grid.Row="0"
                        Width="760"
                        Height="286"
                        HorizontalAlignment="Center"
                        VerticalAlignment="Top"
                        ClipToBounds="False"
                        IsHitTestVisible="False"
                        Visibility="Collapsed">
                <Viewport3D.Camera>
                    <PerspectiveCamera Position="0,0,1050"
                                       LookDirection="0,0,-1050"
                                       UpDirection="0,1,0"
                                       FieldOfView="32.8" />
                </Viewport3D.Camera>
            </Viewport3D>

            <Border Name="CoverFrame"
                    Width="96"
                    Height="96"
                    CornerRadius="4"
                    ClipToBounds="True"
                    Background="#22000000"
                    BorderThickness="1"
                    BorderBrush="#66E6EEF7"
                    VerticalAlignment="Top"
                    HorizontalAlignment="Center"
                    Margin="0,0,0,4"
                    Effect="{StaticResource CoverShadow}">
                <Image Name="CoverImage" Stretch="UniformToFill" />
            </Border>

            <Border Name="InfoBackdrop"
                    Grid.Row="1"
                    Width="192"
                    Height="84"
                    CornerRadius="6"
                    Background="{StaticResource InfoGlow}"
                    HorizontalAlignment="Center"
                    VerticalAlignment="Top" />

            <Grid Name="InfoPanel"
                  Grid.Row="1"
                  Width="188"
                  Height="80"
                  Margin="0,4,0,0"
                  VerticalAlignment="Top"
                  HorizontalAlignment="Center">
                <Grid.RowDefinitions>
                    <RowDefinition Height="42" />
                    <RowDefinition Height="22" />
                    <RowDefinition Height="18" />
                </Grid.RowDefinitions>

                <Viewbox Grid.Row="0" Width="188" Height="42" Stretch="Uniform" StretchDirection="DownOnly">
                    <TextBlock Name="TitleText"
                               FontSize="19"
                               FontWeight="Bold"
                               FontStretch="Expanded"
                               TextWrapping="NoWrap"
                               TextTrimming="None"
                               TextAlignment="Center"
                               VerticalAlignment="Center"
                               HorizontalAlignment="Center"
                               Effect="{StaticResource TextGlow}" />
                </Viewbox>

                <Viewbox Grid.Row="1" Width="188" Height="22" Stretch="Uniform" StretchDirection="DownOnly">
                    <TextBlock Name="ArtistText"
                               FontSize="14"
                               FontStretch="Expanded"
                               TextWrapping="NoWrap"
                               TextTrimming="None"
                               TextAlignment="Center"
                               VerticalAlignment="Center"
                               HorizontalAlignment="Center"
                               Effect="{StaticResource TextGlow}" />
                </Viewbox>

                <Viewbox Grid.Row="2" Width="188" Height="18" Stretch="Uniform" StretchDirection="DownOnly" Visibility="Collapsed" Name="LyricsContainer">
                    <TextBlock Name="LyricsText"
                               FontSize="11"
                               FontStretch="Expanded"
                               TextWrapping="NoWrap"
                               TextTrimming="None"
                               TextAlignment="Center"
                               VerticalAlignment="Center"
                               HorizontalAlignment="Center"
                               Foreground="#A0B8D0"
                               Effect="{StaticResource TextGlow}" />
                </Viewbox>
            </Grid>
        </Grid>
    </Viewbox>
</Window>
