<Window
    x:Class="HorizonRadioOverlay.OverlayWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    Title="Overlay">

    <Grid x:Name="OverlayRoot" Opacity="0">
        <Grid.RowDefinitions>
            <RowDefinition Height="106" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <Border Grid.Row="0"
                Width="96" Height="96" CornerRadius="8"
                HorizontalAlignment="Center" VerticalAlignment="Top" Margin="0,0,0,4"
                Background="#22000000" BorderThickness="1" BorderBrush="#66E6EEF7">
            <Image Name="CoverImage" Stretch="UniformToFill" />
        </Border>

        <Grid Grid.Row="1" Width="188" Height="70" Margin="0,4,0,0" VerticalAlignment="Top" HorizontalAlignment="Center">
            <Grid.RowDefinitions>
                <RowDefinition Height="42" />
                <RowDefinition Height="26" />
            </Grid.RowDefinitions>

            <Viewbox Grid.Row="0" Width="188" Height="42" Stretch="Uniform" StretchDirection="DownOnly">
                <TextBlock Name="TitleText"
                           FontSize="19" FontWeight="Bold"
                           Foreground="#F4F9FF"
                           TextWrapping="NoWrap" TextAlignment="Center"
                           VerticalAlignment="Center" HorizontalAlignment="Center" />
            </Viewbox>

            <Viewbox Grid.Row="1" Width="188" Height="26" Stretch="Uniform" StretchDirection="DownOnly">
                <TextBlock Name="ArtistText"
                           FontSize="15"
                           Foreground="#E2ECF7"
                           TextWrapping="NoWrap" TextAlignment="Center"
                           VerticalAlignment="Center" HorizontalAlignment="Center" />
            </Viewbox>
        </Grid>
    </Grid>
</Window>
