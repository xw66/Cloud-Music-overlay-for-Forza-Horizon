<Window x:Class="HorizonRadioOverlay.MainWindow"
         xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
         xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
         xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
         xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
         mc:Ignorable="d"
         Title="网易云悬浮窗"
         Height="1150"
         Width="1000"
         MinHeight="1150"
         MinWidth="1000"
         Icon="pack://application:,,,/icon.ico"
         WindowStyle="SingleBorderWindow"
         ResizeMode="CanResizeWithGrip"
         WindowStartupLocation="CenterScreen"
         Background="#0D1319"
         Foreground="#EDF2F7"
         FontFamily="Segoe UI Semibold">
    <Window.Resources>
        <SolidColorBrush x:Key="PanelBrush" Color="#1A2633" />
        <SolidColorBrush x:Key="PanelSoftBrush" Color="#141E29" />
        <SolidColorBrush x:Key="AccentBrush" Color="#D96A2F" />

        <Style TargetType="Button">
            <Setter Property="Foreground" Value="#F7FBFF" />
            <Setter Property="Background" Value="#26384A" />
            <Setter Property="BorderBrush" Value="#365066" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Padding" Value="12,6" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="8">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#314B62" />
                    <Setter Property="BorderBrush" Value="#4A6B86" />
                </Trigger>
                <Trigger Property="IsPressed" Value="True">
                    <Setter Property="Background" Value="#223648" />
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style TargetType="Slider">
            <Setter Property="Foreground" Value="#D96A2F" />
        </Style>
    </Window.Resources>

        <Grid Margin="20" Background="#101922">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

            <Border Padding="16" CornerRadius="14" Background="{StaticResource PanelBrush}" BorderThickness="1" BorderBrush="#2F4153">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <StackPanel Grid.Column="0">
                        <TextBlock Text="网易云悬浮窗" FontSize="27" FontWeight="Bold" Foreground="#F4F8FC" />
                        <TextBlock Margin="0,6,0,0" Opacity="0.88" Foreground="#D6E0EA"
                                   Text="支持自定义游戏快捷键，歌曲变化时悬浮窗自动弹出。数据来源支持网易云窗口标题和 SMTC（QQ音乐/Apple Music 等）。" />
                    </StackPanel>
                    <Button Grid.Column="1" VerticalAlignment="Top" Width="40" Height="40" Padding="6"
                            Background="#2D3F50" BorderBrush="#4A6787" Click="GitHubButton_Click"
                            ToolTip="在 GitHub 上查看源码">
                        <Image Source="pack://application:,,,/Assets/Icons/icons8-github-50.png" Stretch="Uniform" />
                    </Button>
                </Grid>
            </Border>

            <Border Grid.Row="1" Margin="0,14,0,0" Padding="14" CornerRadius="14" Background="{StaticResource PanelBrush}" BorderThickness="1" BorderBrush="#2C3E50">
                <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="130" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>

                <Border Width="116" Height="116" CornerRadius="12" ClipToBounds="True" VerticalAlignment="Top" Background="#2A394B" BorderThickness="1" BorderBrush="#49637A">
                    <Image Name="CoverPreview" Stretch="UniformToFill" />
                </Border>

                <StackPanel Grid.Column="1" Margin="14,0,0,0">
                    <TextBlock Name="CurrentTitle" FontSize="24" FontWeight="Bold" Foreground="#F6FAFF" TextWrapping="Wrap" Text="未检测到播放中的歌曲" />
                    <TextBlock Name="CurrentArtist" Margin="0,6,0,0" Opacity="0.86" Foreground="#D6E1EA" Text="请先打开网易云音乐并播放" />
                    <TextBlock Name="CurrentMeta" Margin="0,6,0,0" Opacity="0.75" Foreground="#AFC0D0" Text="来源：-" />

                    <StackPanel Orientation="Horizontal" Margin="0,14,0,0">
                        <Button Width="100" Height="34" Content="上一首" Click="Prev_Click" />
                        <Button Width="112" Height="34" Margin="8,0,0,0" Content="播放/暂停" Click="PlayPause_Click" Background="#2E4358" BorderBrush="#4D6B85" />
                        <Button Width="100" Height="34" Margin="8,0,0,0" Content="下一首" Click="Next_Click" />
                        <Button Width="100" Height="34" Margin="8,0,0,0" Content="刷新" Click="Refresh_Click" Background="#6B3A21" BorderBrush="#905437" />
                    </StackPanel>

                    <Border Margin="0,18,0,0" Padding="14" CornerRadius="12" Background="{StaticResource PanelSoftBrush}" BorderThickness="1" BorderBrush="#2E4254">
                        <StackPanel>
                            <TextBlock Text="悬浮窗位置与大小" FontSize="16" FontWeight="Bold" Foreground="#EEF5FC" />

                            <TextBlock Margin="0,10,0,0" Opacity="0.88" Foreground="#D1DEE9" Text="歌曲数据来源" />
                            <ComboBox Name="TrackSourceComboBox" Margin="0,4,0,0" Height="30" SelectedIndex="0" SelectionChanged="TrackSourceComboBox_SelectionChanged">
                                <ComboBoxItem Tag="NeteaseProcess" Content="网易云窗口标题" />
                                <ComboBoxItem Tag="SMTC" Content="QQ音乐 / Apple Music 等（SMTC）" />
                            </ComboBox>

                            <TextBlock Margin="0,11,0,0" Opacity="0.88" Foreground="#D1DEE9" Text="水平位置（从左侧）" />
                            <Grid Margin="0,4,0,0">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <Slider Name="HorizontalSlider" Grid.Column="0" Minimum="0" Maximum="40" ValueChanged="HorizontalSlider_ValueChanged" />
                                <TextBlock Name="HorizontalValueText" Grid.Column="1" Margin="12,0,0,0" VerticalAlignment="Center" Opacity="0.92" Foreground="#E6EFF8" Text="0%" />
                            </Grid>

                            <TextBlock Margin="0,9,0,0" Opacity="0.88" Foreground="#D1DEE9" Text="垂直位置（从顶部）" />
                            <Grid Margin="0,4,0,0">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <Slider Name="BottomOffsetSlider" Grid.Column="0" Minimum="0" Maximum="80" ValueChanged="BottomOffsetSlider_ValueChanged" />
                                <TextBlock Name="BottomOffsetValueText" Grid.Column="1" Margin="12,0,0,0" VerticalAlignment="Center" Opacity="0.92" Foreground="#E6EFF8" Text="0%" />
                            </Grid>

                            <TextBlock Margin="0,9,0,0" Opacity="0.88" Foreground="#D1DEE9" Text="悬浮窗缩放" />
                            <Grid Margin="0,4,0,0">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <Slider Name="ScaleSlider" Grid.Column="0" Minimum="80" Maximum="180" ValueChanged="ScaleSlider_ValueChanged" />
                                <TextBlock Name="ScaleValueText" Grid.Column="1" Margin="12,0,0,0" VerticalAlignment="Center" Opacity="0.92" Foreground="#E6EFF8" Text="100%" />
                            </Grid>

                            <TextBlock Margin="0,12,0,0" FontSize="15" FontWeight="Bold" Foreground="#EEF5FC" Text="快捷键映射" />
                            <TextBlock Margin="0,4,0,0" Opacity="0.82" Foreground="#C7D7E6" Text="左侧填写游戏内按键，右侧填写要转发给网易云的按键。" />

                            <Grid Margin="0,8,0,0">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>

                                <StackPanel Grid.Column="0" Margin="0,0,8,0">
                                    <TextBlock FontSize="13" FontWeight="SemiBold" Foreground="#E8F0F8" Text="应用快捷键（游戏内按）" />
                                    <TextBlock Margin="0,6,0,0" Opacity="0.85" Foreground="#C7D7E6" Text="上一首" />
                                    <TextBox Name="AppPrevHotkeyBox" Margin="0,2,0,0" Height="28" Text="Ctrl+Shift+Left" />
                                    <TextBlock Margin="0,6,0,0" Opacity="0.85" Foreground="#C7D7E6" Text="下一首" />
                                    <TextBox Name="AppNextHotkeyBox" Margin="0,2,0,0" Height="28" Text="Ctrl+Shift+Right" />
                                    <TextBlock Margin="0,6,0,0" Opacity="0.85" Foreground="#C7D7E6" Text="播放/暂停" />
                                    <TextBox Name="AppToggleHotkeyBox" Margin="0,2,0,0" Height="28" Text="Ctrl+Shift+Down" />
                                </StackPanel>

                                <StackPanel Grid.Column="1" Margin="8,0,0,0">
                                    <TextBlock FontSize="13" FontWeight="SemiBold" Foreground="#E8F0F8" Text="网易云快捷键（转发）" />
                                    <TextBlock Margin="0,6,0,0" Opacity="0.85" Foreground="#C7D7E6" Text="上一首" />
                                    <TextBox Name="NeteasePrevHotkeyBox" Margin="0,2,0,0" Height="28" Text="Ctrl+Alt+Left" />
                                    <TextBlock Margin="0,6,0,0" Opacity="0.85" Foreground="#C7D7E6" Text="下一首" />
                                    <TextBox Name="NeteaseNextHotkeyBox" Margin="0,2,0,0" Height="28" Text="Ctrl+Alt+Right" />
                                    <TextBlock Margin="0,6,0,0" Opacity="0.85" Foreground="#C7D7E6" Text="播放/暂停" />
                                    <TextBox Name="NeteaseToggleHotkeyBox" Margin="0,2,0,0" Height="28" Text="Ctrl+Alt+P" />
                                </StackPanel>
                            </Grid>

                            <TextBlock Margin="0,12,0,0" FontSize="15" FontWeight="Bold" Foreground="#EEF5FC" Text="手柄快捷键" />
                            <CheckBox Name="EnableGamepadCheckBox" Margin="0,6,0,0" Content="启用 Xbox 手柄快捷键" Foreground="#E8F0F8" />
                            <TextBlock Margin="0,4,0,0" Opacity="0.82" Foreground="#C7D7E6" Text="支持组合按键，用 + 连接，例如 LT+RT+Y" />

                            <Grid Margin="0,8,0,0">
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="32" />
                                    <RowDefinition Height="32" />
                                    <RowDefinition Height="32" />
                                </Grid.RowDefinitions>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>

                                <TextBlock Grid.Row="0" Grid.Column="0" VerticalAlignment="Center" Opacity="0.9" Foreground="#D1DEE9" Text="上一首" />
                                <TextBox Name="GamepadPrevHotkeyBox" Grid.Row="0" Grid.Column="1" Margin="8,0,0,0" Height="28" VerticalAlignment="Center" Text="LB+Left" />

                                <TextBlock Grid.Row="1" Grid.Column="0" VerticalAlignment="Center" Opacity="0.9" Foreground="#D1DEE9" Text="下一首" />
                                <TextBox Name="GamepadNextHotkeyBox" Grid.Row="1" Grid.Column="1" Margin="8,0,0,0" Height="28" VerticalAlignment="Center" Text="RB+Right" />

                                <TextBlock Grid.Row="2" Grid.Column="0" VerticalAlignment="Center" Opacity="0.9" Foreground="#D1DEE9" Text="播放/暂停" />
                                <TextBox Name="GamepadToggleHotkeyBox" Grid.Row="2" Grid.Column="1" Margin="8,0,0,0" Height="28" VerticalAlignment="Center" Text="LT+RT+Y" />
                            </Grid>

                            <TextBlock Margin="0,12,0,0" FontSize="15" FontWeight="Bold" Foreground="#EEF5FC" Text="其他设置" />
                            <CheckBox Name="MinimizeToTrayCheckBox" Margin="0,8,0,0" Content="关闭窗口时最小化到系统托盘" Foreground="#E8F0F8" IsChecked="True" />
                            <CheckBox Name="AutoStartCheckBox" Margin="0,6,0,0" Content="开机自启动" Foreground="#E8F0F8" />

                            <StackPanel Orientation="Horizontal" Margin="0,12,0,0">
                                <Button Width="98" Height="32" Content="保存" Click="SaveOverlaySettings_Click" Background="#2F5A3A" BorderBrush="#4A7E57" />
                                <Button Width="98" Height="32" Margin="8,0,0,0" Content="重置" Click="ResetOverlaySettings_Click" />
                                <Button Width="98" Height="32" Margin="8,0,0,0" Content="测试" Click="TestOverlay_Click" Background="#2F4A67" BorderBrush="#4A6787" />
                            </StackPanel>
                        </StackPanel>
                    </Border>
                </StackPanel>
                </Grid>
            </Border>

            <Border Grid.Row="2" Margin="0,12,0,0" Padding="10,8" CornerRadius="9" Background="#111920" BorderThickness="1" BorderBrush="#2B3B4C">
                <TextBlock Name="StatusText" Opacity="0.9" Foreground="#DCE7F2" Text="状态：空闲" />
            </Border>
        </Grid>
</Window>
