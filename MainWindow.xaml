<Window x:Class="HorizonRadioOverlay.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="网易云悬浮窗"
        MinHeight="500"
        MinWidth="900"
        WindowStyle="SingleBorderWindow"
        ResizeMode="CanResizeWithGrip"
        WindowStartupLocation="CenterScreen"
        Background="#0D1319"
        Foreground="#EDF2F7"
        FontFamily="Segoe UI Semibold">
    <Window.Resources>
        <SolidColorBrush x:Key="PanelBrush" Color="#1A2633" />
        <SolidColorBrush x:Key="PanelSoftBrush" Color="#141E29" />
        <SolidColorBrush x:Key="AccentBrush" Color="#D96A2F" />

        <Style TargetType="Button">
            <Setter Property="Foreground" Value="#F7FBFF" />
            <Setter Property="Background" Value="#26384A" />
            <Setter Property="BorderBrush" Value="#365066" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Padding" Value="12,6" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="8">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#314B62" />
                    <Setter Property="BorderBrush" Value="#4A6B86" />
                </Trigger>
                <Trigger Property="IsPressed" Value="True">
                    <Setter Property="Background" Value="#223648" />
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style TargetType="Slider">
            <Setter Property="Foreground" Value="#D96A2F" />
        </Style>
    </Window.Resources>

    <Grid Background="#101922">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <!-- 顶栏 -->
        <Border Grid.Row="0" Padding="20,14" Background="{StaticResource PanelBrush}" BorderThickness="0,0,0,1" BorderBrush="#2F4153">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center">
                    <TextBlock Text="网易云悬浮窗" FontSize="22" FontWeight="Bold" Foreground="#F4F8FC" VerticalAlignment="Center" />
                    <TextBlock Margin="16,0,0,0" Opacity="0.7" Foreground="#A0B0C0" FontSize="13" VerticalAlignment="Center"
                               Text="支持网易云窗口标题 / SMTC（QQ音乐/Apple Music）" />
                </StackPanel>
                <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                    <Button Width="90" Height="32" Padding="6" Margin="0,0,8,0"
                            Background="#2D3F50" BorderBrush="#4A6787" Click="CheckUpdate_Click"
                            ToolTip="检查 GitHub 是否有新版本">
                        <TextBlock Text="检查更新" FontSize="12" />
                    </Button>
                    <Button Width="36" Height="36" Padding="6"
                            Background="#2D3F50" BorderBrush="#4A6787" Click="GitHubButton_Click"
                            ToolTip="在 GitHub 上查看源码">
                        <Image Name="GitHubImage" Stretch="Uniform" />
                    </Button>
                </StackPanel>
            </Grid>
        </Border>

        <!-- 主内容区：左右布局 -->
        <Grid Grid.Row="1" Margin="16,12">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="260" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <!-- 左侧：正在播放 -->
            <Border Grid.Column="0" Padding="16" CornerRadius="12" Background="{StaticResource PanelBrush}" BorderThickness="1" BorderBrush="#2C3E50" VerticalAlignment="Stretch">
                <StackPanel VerticalAlignment="Top">
                    <TextBlock Text="正在播放" FontSize="13" FontWeight="SemiBold" Foreground="#8899AA" />

                    <Border Margin="0,10,0,0" Width="120" Height="120" CornerRadius="10" ClipToBounds="True"
                            HorizontalAlignment="Center" Background="#2A394B" BorderThickness="1" BorderBrush="#49637A">
                        <Image Name="CoverPreview" Stretch="UniformToFill" />
                    </Border>

                    <TextBlock Name="CurrentTitle" Margin="0,12,0,0" FontSize="18" FontWeight="Bold"
                               Foreground="#F6FAFF" TextWrapping="Wrap" TextAlignment="Center"
                               Text="未检测到播放中的歌曲" />
                    <TextBlock Name="CurrentArtist" Margin="0,4,0,0" Opacity="0.86" Foreground="#D6E1EA"
                               TextAlignment="Center" Text="请先打开网易云音乐并播放" />
                    <TextBlock Name="CurrentMeta" Margin="0,4,0,0" Opacity="0.7" Foreground="#AFC0D0"
                               FontSize="12" TextAlignment="Center" Text="来源：-" />

                    <StackPanel Orientation="Horizontal" Margin="0,14,0,0" HorizontalAlignment="Center">
                        <Button Width="70" Height="32" Content="⏮" Click="Prev_Click" />
                        <Button Width="70" Height="32" Margin="6,0,0,0" Content="⏯" Click="PlayPause_Click" Background="#2E4358" BorderBrush="#4D6B85" />
                        <Button Width="70" Height="32" Margin="6,0,0,0" Content="⏭" Click="Next_Click" />
                        <Button Width="70" Height="32" Margin="6,0,0,0" Content="⟳" Click="Refresh_Click" Background="#6B3A21" BorderBrush="#905437" />
                    </StackPanel>
                </StackPanel>
            </Border>

            <!-- 右侧：设置面板 -->
            <Border Grid.Column="1" Margin="12,0,0,0" Padding="16" CornerRadius="12" Background="{StaticResource PanelBrush}" BorderThickness="1" BorderBrush="#2C3E50">
                <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
                    <StackPanel>
                        <!-- 数据来源 -->
                        <TextBlock Text="悬浮窗设置" FontSize="15" FontWeight="Bold" Foreground="#EEF5FC" />
                        <TextBlock Margin="0,10,0,0" Opacity="0.85" Foreground="#D1DEE9" Text="歌曲数据来源" />
                        <ComboBox Name="TrackSourceComboBox" Margin="0,4,0,0" Height="30" SelectedIndex="0" SelectionChanged="TrackSourceComboBox_SelectionChanged">
                            <ComboBoxItem Tag="NeteaseProcess" Content="网易云窗口标题" />
                            <ComboBoxItem Tag="SMTC" Content="QQ音乐 / Apple Music 等（SMTC）" />
                        </ComboBox>

                        <!-- 位置与缩放 -->
                        <Grid Margin="0,14,0,0">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>

                            <StackPanel Grid.Column="0" Margin="0,0,8,0">
                                <TextBlock Opacity="0.85" Foreground="#D1DEE9" Text="水平位置" />
                                <Grid Margin="0,4,0,0">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>
                                    <Slider Name="HorizontalSlider" Grid.Column="0" Minimum="0" Maximum="40" ValueChanged="HorizontalSlider_ValueChanged" />
                                    <TextBlock Name="HorizontalValueText" Grid.Column="1" Margin="8,0,0,0" VerticalAlignment="Center" Opacity="0.9" Foreground="#E6EFF8" Text="0%" />
                                </Grid>
                            </StackPanel>

                            <StackPanel Grid.Column="1" Margin="4,0,4,0">
                                <TextBlock Opacity="0.85" Foreground="#D1DEE9" Text="垂直位置" />
                                <Grid Margin="0,4,0,0">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>
                                    <Slider Name="BottomOffsetSlider" Grid.Column="0" Minimum="0" Maximum="80" ValueChanged="BottomOffsetSlider_ValueChanged" />
                                    <TextBlock Name="BottomOffsetValueText" Grid.Column="1" Margin="8,0,0,0" VerticalAlignment="Center" Opacity="0.9" Foreground="#E6EFF8" Text="0%" />
                                </Grid>
                            </StackPanel>

                            <StackPanel Grid.Column="2" Margin="8,0,0,0">
                                <TextBlock Opacity="0.85" Foreground="#D1DEE9" Text="缩放" />
                                <Grid Margin="0,4,0,0">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>
                                    <Slider Name="ScaleSlider" Grid.Column="0" Minimum="80" Maximum="180" ValueChanged="ScaleSlider_ValueChanged" />
                                    <TextBlock Name="ScaleValueText" Grid.Column="1" Margin="8,0,0,0" VerticalAlignment="Center" Opacity="0.9" Foreground="#E6EFF8" Text="100%" />
                                </Grid>
                            </StackPanel>
                        </Grid>

                        <!-- 快捷键映射 -->
                        <Border Margin="0,14,0,0" Padding="12" CornerRadius="10" Background="{StaticResource PanelSoftBrush}" BorderThickness="1" BorderBrush="#2E4254">
                            <StackPanel>
                                <TextBlock FontSize="14" FontWeight="Bold" Foreground="#EEF5FC" Text="快捷键映射" />
                                <TextBlock Margin="0,4,0,0" Opacity="0.75" Foreground="#8899AA" FontSize="12" Text="左侧游戏内按键，右侧转发给网易云" />

                                <Grid Margin="0,10,0,0">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="*" />
                                    </Grid.ColumnDefinitions>

                                    <StackPanel Grid.Column="0" Margin="0,0,8,0">
                                        <TextBlock FontSize="12" FontWeight="SemiBold" Foreground="#E8F0F8" Text="应用快捷键（游戏内按）" />
                                        <TextBlock Margin="0,8,0,0" Opacity="0.8" Foreground="#B0C0D0" Text="上一首" />
                                        <TextBox Name="AppPrevHotkeyBox" Margin="0,2,0,0" Height="26" Text="Ctrl+Shift+Left" />
                                        <TextBlock Margin="0,6,0,0" Opacity="0.8" Foreground="#B0C0D0" Text="下一首" />
                                        <TextBox Name="AppNextHotkeyBox" Margin="0,2,0,0" Height="26" Text="Ctrl+Shift+Right" />
                                        <TextBlock Margin="0,6,0,0" Opacity="0.8" Foreground="#B0C0D0" Text="播放/暂停" />
                                        <TextBox Name="AppToggleHotkeyBox" Margin="0,2,0,0" Height="26" Text="Ctrl+Shift+Down" />
                                    </StackPanel>

                                    <StackPanel Grid.Column="1" Margin="8,0,0,0">
                                        <TextBlock FontSize="12" FontWeight="SemiBold" Foreground="#E8F0F8" Text="网易云快捷键（转发）" />
                                        <TextBlock Margin="0,8,0,0" Opacity="0.8" Foreground="#B0C0D0" Text="上一首" />
                                        <TextBox Name="NeteasePrevHotkeyBox" Margin="0,2,0,0" Height="26" Text="Ctrl+Alt+Left" />
                                        <TextBlock Margin="0,6,0,0" Opacity="0.8" Foreground="#B0C0D0" Text="下一首" />
                                        <TextBox Name="NeteaseNextHotkeyBox" Margin="0,2,0,0" Height="26" Text="Ctrl+Alt+Right" />
                                        <TextBlock Margin="0,6,0,0" Opacity="0.8" Foreground="#B0C0D0" Text="播放/暂停" />
                                        <TextBox Name="NeteaseToggleHotkeyBox" Margin="0,2,0,0" Height="26" Text="Ctrl+Alt+P" />
                                    </StackPanel>
                                </Grid>
                            </StackPanel>
                        </Border>

                        <!-- 手柄 + 其他设置 -->
                        <Grid Margin="0,14,0,0">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>

                            <!-- 手柄 -->
                            <StackPanel Grid.Column="0" Margin="0,0,8,0">
                                <TextBlock FontSize="14" FontWeight="Bold" Foreground="#EEF5FC" Text="手柄快捷键" />
                                <CheckBox Name="EnableGamepadCheckBox" Margin="0,8,0,0" Content="启用 Xbox 手柄" Foreground="#E8F0F8" />
                                <TextBlock Margin="0,4,0,0" Opacity="0.7" Foreground="#8899AA" FontSize="11" Text="组合键用 + 连接，如 LT+RT+Y" />

                                <TextBlock Margin="0,10,0,0" Opacity="0.8" Foreground="#B0C0D0" Text="上一首" />
                                <TextBox Name="GamepadPrevHotkeyBox" Margin="0,2,0,0" Height="26" VerticalAlignment="Center" Text="LB+Left" />
                                <TextBlock Margin="0,6,0,0" Opacity="0.8" Foreground="#B0C0D0" Text="下一首" />
                                <TextBox Name="GamepadNextHotkeyBox" Margin="0,2,0,0" Height="26" VerticalAlignment="Center" Text="RB+Right" />
                                <TextBlock Margin="0,6,0,0" Opacity="0.8" Foreground="#B0C0D0" Text="播放/暂停" />
                                <TextBox Name="GamepadToggleHotkeyBox" Margin="0,2,0,0" Height="26" VerticalAlignment="Center" Text="LT+RT+Y" />
                            </StackPanel>

                            <!-- 其他设置 -->
                            <StackPanel Grid.Column="1" Margin="8,0,0,0">
                                <TextBlock FontSize="14" FontWeight="Bold" Foreground="#EEF5FC" Text="其他设置" />
                                <CheckBox Name="MinimizeToTrayCheckBox" Margin="0,10,0,0" Content="关闭时最小化到托盘" Foreground="#E8F0F8" IsChecked="True" />
                                <CheckBox Name="AutoStartCheckBox" Margin="0,8,0,0" Content="开机自启动" Foreground="#E8F0F8" />

                                <StackPanel Orientation="Horizontal" Margin="0,20,0,0">
                                    <Button Width="88" Height="30" Content="保存" Click="SaveOverlaySettings_Click" Background="#2F5A3A" BorderBrush="#4A7E57" />
                                    <Button Width="88" Height="30" Margin="8,0,0,0" Content="重置" Click="ResetOverlaySettings_Click" />
                                    <Button Width="88" Height="30" Margin="8,0,0,0" Content="测试" Click="TestOverlay_Click" Background="#2F4A67" BorderBrush="#4A6787" />
                                </StackPanel>
                            </StackPanel>
                        </Grid>
                    </StackPanel>
                </ScrollViewer>
            </Border>
        </Grid>

        <!-- 状态栏 -->
        <Border Grid.Row="2" Margin="16,0,16,12" Padding="10,8" CornerRadius="8" Background="#111920" BorderThickness="1" BorderBrush="#2B3B4C">
            <TextBlock Name="StatusText" Opacity="0.9" Foreground="#DCE7F2" Text="状态：空闲" FontSize="12" />
        </Border>
    </Grid>
</Window>
