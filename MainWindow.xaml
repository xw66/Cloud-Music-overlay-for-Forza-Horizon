<Window
    x:Class="HorizonRadioOverlay.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    Title="网易云悬浮窗">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <!-- Header -->
        <Grid Grid.Row="0" Padding="24,14" x:Name="TitleBar">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>
            <StackPanel Grid.Column="0" VerticalAlignment="Center">
                <TextBlock Text="网易云悬浮窗" FontSize="22" FontWeight="SemiBold" />
                <TextBlock Margin="0,2,0,0" FontSize="12" Opacity="0.7"
                           Text="支持网易云窗口标题与 SMTC（QQ音乐/Apple Music 等）" />
            </StackPanel>
            <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center" Spacing="8">
                <Button Content="检查更新" Click="CheckUpdate_Click" />
                <Button Click="GitHubButton_Click" Padding="8,6">
                    <Image Name="GitHubImage" Width="18" Height="18" />
                </Button>
            </StackPanel>
        </Grid>

        <!-- Main Content -->
        <Grid Grid.Row="1" Margin="24,0,24,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="300" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <!-- Left: Now Playing -->
            <Border Grid.Column="0" Padding="20" CornerRadius="12"
                    Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                    BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" BorderThickness="1">
                <StackPanel Spacing="4">
                    <TextBlock Text="正在播放" FontSize="11" FontWeight="SemiBold" Opacity="0.5" />
                    <Border Width="120" Height="120" CornerRadius="12"
                            HorizontalAlignment="Center" Margin="0,8,0,0"
                            Background="{ThemeResource LayerFillColorDefaultBrush}"
                            BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" BorderThickness="1">
                        <Image Name="CoverPreview" Stretch="UniformToFill" />
                    </Border>
                    <TextBlock Name="CurrentTitle" FontSize="18" FontWeight="SemiBold"
                               TextWrapping="Wrap" TextAlignment="Center" Margin="0,10,0,0"
                               Text="未检测到播放中的歌曲" />
                    <TextBlock Name="CurrentArtist" FontSize="13" Opacity="0.7"
                               TextAlignment="Center" Text="请先打开网易云音乐并播放" />
                    <TextBlock Name="CurrentMeta" FontSize="11" Opacity="0.5"
                               TextAlignment="Center" Text="来源：-" />

                    <Grid Margin="0,12,0,0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <Button Grid.Column="0" Margin="0,0,4,0" Click="Prev_Click" Content="⏮" />
                        <Button Grid.Column="1" Margin="4,0,4,0" Click="PlayPause_Click" Content="⏯" />
                        <Button Grid.Column="2" Margin="4,0,4,0" Click="Next_Click" Content="⏭" />
                        <Button Grid.Column="3" Margin="4,0,0,0" Click="Refresh_Click" Content="⟳"
                                Style="{ThemeResource AccentButtonStyle}" />
                    </Grid>
                </StackPanel>
            </Border>

            <!-- Right: Settings -->
            <Border Grid.Column="1" Margin="14,0,0,0" Padding="20" CornerRadius="12"
                    Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                    BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" BorderThickness="1">
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <StackPanel Spacing="4">
                        <TextBlock Text="悬浮窗" FontSize="12" FontWeight="SemiBold" Opacity="0.5" />
                        <Grid Margin="0,8,0,0">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <StackPanel Grid.Column="0" Margin="0,0,10,0">
                                <TextBlock Text="数据来源" FontSize="11" Opacity="0.6" />
                                <ComboBox Name="TrackSourceComboBox" Margin="0,4,0,0" SelectedIndex="0"
                                          SelectionChanged="TrackSourceComboBox_SelectionChanged">
                                    <ComboBoxItem Tag="NeteaseProcess" Content="网易云窗口标题" />
                                    <ComboBoxItem Tag="SMTC" Content="QQ音乐 / Apple Music" />
                                </ComboBox>
                                <TextBlock FontSize="10" Opacity="0.4" Margin="0,4,0,0" Text="漫游模式无封面" />
                            </StackPanel>
                            <StackPanel Grid.Column="1" Margin="5,0,5,0">
                                <TextBlock Text="水平位置" FontSize="11" Opacity="0.6" />
                                <Grid Margin="0,4,0,0">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="36" />
                                    </Grid.ColumnDefinitions>
                                    <Slider Name="HorizontalSlider" Grid.Column="0" Minimum="0" Maximum="40"
                                            ValueChanged="HorizontalSlider_ValueChanged" />
                                    <TextBlock Name="HorizontalValueText" Grid.Column="1" FontSize="11" Opacity="0.5"
                                               VerticalAlignment="Center" TextAlignment="Right" Text="0%" />
                                </Grid>
                            </StackPanel>
                            <StackPanel Grid.Column="2" Margin="10,0,0,0">
                                <TextBlock Text="垂直位置" FontSize="11" Opacity="0.6" />
                                <Grid Margin="0,4,0,0">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="36" />
                                    </Grid.ColumnDefinitions>
                                    <Slider Name="BottomOffsetSlider" Grid.Column="0" Minimum="0" Maximum="80"
                                            ValueChanged="BottomOffsetSlider_ValueChanged" />
                                    <TextBlock Name="BottomOffsetValueText" Grid.Column="1" FontSize="11" Opacity="0.5"
                                               VerticalAlignment="Center" TextAlignment="Right" Text="0%" />
                                </Grid>
                            </StackPanel>
                        </Grid>

                        <Grid Margin="0,4,0,0">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <StackPanel Grid.Column="0" Margin="0,0,10,0">
                                <TextBlock Text="缩放" FontSize="11" Opacity="0.6" />
                                <Grid Margin="0,4,0,0">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="36" />
                                    </Grid.ColumnDefinitions>
                                    <Slider Name="ScaleSlider" Grid.Column="0" Minimum="80" Maximum="180"
                                            ValueChanged="ScaleSlider_ValueChanged" />
                                    <TextBlock Name="ScaleValueText" Grid.Column="1" FontSize="11" Opacity="0.5"
                                               VerticalAlignment="Center" TextAlignment="Right" Text="100%" />
                                </Grid>
                            </StackPanel>
                            <StackPanel Grid.Column="1" Margin="5,0,5,0">
                                <TextBlock Text="歌名颜色" FontSize="11" Opacity="0.6" />
                                <StackPanel Orientation="Horizontal" Margin="0,6,0,0" Spacing="6">
                                    <RadioButton x:Name="TitleColor_White" Background="White" IsChecked="True" Click="TitleColor_Click" Tag="#FFFFFF" />
                                    <RadioButton x:Name="TitleColor_Light" Background="#C8D4E8" Click="TitleColor_Click" Tag="#C8D4E8" />
                                    <RadioButton x:Name="TitleColor_Blue" Background="#7CB3F0" Click="TitleColor_Click" Tag="#7CB3F0" />
                                    <RadioButton x:Name="TitleColor_Purple" Background="#B090F0" Click="TitleColor_Click" Tag="#B090F0" />
                                    <RadioButton x:Name="TitleColor_Green" Background="#7DD4A0" Click="TitleColor_Click" Tag="#7DD4A0" />
                                    <RadioButton x:Name="TitleColor_Orange" Background="#F0A060" Click="TitleColor_Click" Tag="#F0A060" />
                                </StackPanel>
                                <Grid Margin="0,4,0,0">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="36" />
                                    </Grid.ColumnDefinitions>
                                    <Slider Name="TitleOpacitySlider" Grid.Column="0" Minimum="0" Maximum="100" Value="100"
                                            ValueChanged="TitleOpacitySlider_ValueChanged" />
                                    <TextBlock Name="TitleOpacityValueText" Grid.Column="1" FontSize="11" Opacity="0.5"
                                               VerticalAlignment="Center" TextAlignment="Right" Text="100%" />
                                </Grid>
                            </StackPanel>
                            <StackPanel Grid.Column="2" Margin="10,0,0,0">
                                <TextBlock Text="歌手颜色" FontSize="11" Opacity="0.6" />
                                <StackPanel Orientation="Horizontal" Margin="0,6,0,0" Spacing="6">
                                    <RadioButton x:Name="ArtistColor_Light" Background="#C4C9D4" IsChecked="True" Click="ArtistColor_Click" Tag="#C4C9D4" />
                                    <RadioButton x:Name="ArtistColor_White" Background="White" Click="ArtistColor_Click" Tag="#FFFFFF" />
                                    <RadioButton x:Name="ArtistColor_Blue" Background="#7CB3F0" Click="ArtistColor_Click" Tag="#7CB3F0" />
                                    <RadioButton x:Name="ArtistColor_Purple" Background="#B090F0" Click="ArtistColor_Click" Tag="#B090F0" />
                                    <RadioButton x:Name="ArtistColor_Green" Background="#7DD4A0" Click="ArtistColor_Click" Tag="#7DD4A0" />
                                    <RadioButton x:Name="ArtistColor_Orange" Background="#F0A060" Click="ArtistColor_Click" Tag="#F0A060" />
                                </StackPanel>
                                <Grid Margin="0,4,0,0">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="36" />
                                    </Grid.ColumnDefinitions>
                                    <Slider Name="ArtistOpacitySlider" Grid.Column="0" Minimum="0" Maximum="100" Value="100"
                                            ValueChanged="ArtistOpacitySlider_ValueChanged" />
                                    <TextBlock Name="ArtistOpacityValueText" Grid.Column="1" FontSize="11" Opacity="0.5"
                                               VerticalAlignment="Center" TextAlignment="Right" Text="100%" />
                                </Grid>
                            </StackPanel>
                        </Grid>

                        <TextBlock Text="快捷键映射：左侧游戏内按键，右侧转发给网易云" FontSize="11" Opacity="0.4" Margin="0,4,0,0" />

                        <Grid Margin="0,4,0,0">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <StackPanel Grid.Column="0" Margin="0,0,8,0" Spacing="4">
                                <TextBlock Text="应用快捷键" FontSize="11" FontWeight="SemiBold" Opacity="0.6" />
                                <TextBlock Text="上一首" FontSize="11" Opacity="0.4" />
                                <TextBox Name="AppPrevHotkeyBox" Height="32" Text="Ctrl+Shift+Left" />
                                <TextBlock Text="下一首" FontSize="11" Opacity="0.4" />
                                <TextBox Name="AppNextHotkeyBox" Height="32" Text="Ctrl+Shift+Right" />
                                <TextBlock Text="播放/暂停" FontSize="11" Opacity="0.4" />
                                <TextBox Name="AppToggleHotkeyBox" Height="32" Text="Ctrl+Shift+Down" />
                            </StackPanel>
                            <StackPanel Grid.Column="1" Margin="8,0,0,0" Spacing="4">
                                <TextBlock Text="网易云快捷键" FontSize="11" FontWeight="SemiBold" Opacity="0.6" />
                                <TextBlock Text="上一首" FontSize="11" Opacity="0.4" />
                                <TextBox Name="NeteasePrevHotkeyBox" Height="32" Text="Ctrl+Alt+Left" />
                                <TextBlock Text="下一首" FontSize="11" Opacity="0.4" />
                                <TextBox Name="NeteaseNextHotkeyBox" Height="32" Text="Ctrl+Alt+Right" />
                                <TextBlock Text="播放/暂停" FontSize="11" Opacity="0.4" />
                                <TextBox Name="NeteaseToggleHotkeyBox" Height="32" Text="Ctrl+Alt+P" />
                            </StackPanel>
                        </Grid>

                        <TextBlock Text="手柄快捷键" FontSize="12" FontWeight="SemiBold" Opacity="0.5" Margin="0,8,0,0" />
                        <CheckBox Name="EnableGamepadCheckBox" Content="启用 Xbox 手柄" />
                        <Grid Margin="0,4,0,0">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <StackPanel Grid.Column="0" Margin="0,0,8,0">
                                <TextBlock Text="上一首" FontSize="11" Opacity="0.4" />
                                <TextBox Name="GamepadPrevHotkeyBox" Height="32" Text="LB+Left" />
                            </StackPanel>
                            <StackPanel Grid.Column="1" Margin="4,0,4,0">
                                <TextBlock Text="下一首" FontSize="11" Opacity="0.4" />
                                <TextBox Name="GamepadNextHotkeyBox" Height="32" Text="RB+Right" />
                            </StackPanel>
                            <StackPanel Grid.Column="2" Margin="8,0,0,0">
                                <TextBlock Text="播放/暂停" FontSize="11" Opacity="0.4" />
                                <TextBox Name="GamepadToggleHotkeyBox" Height="32" Text="LT+RT+Y" />
                            </StackPanel>
                        </Grid>

                        <TextBlock Text="系统" FontSize="12" FontWeight="SemiBold" Opacity="0.5" Margin="0,8,0,0" />
                        <CheckBox Name="MinimizeToTrayCheckBox" Content="关闭窗口时最小化到系统托盘" IsChecked="True" />
                        <CheckBox Name="AutoStartCheckBox" Content="开机自启动" />

                        <TextBox x:Name="TitleColorBox" Visibility="Collapsed" Text="#FFFFFF" />
                        <TextBox x:Name="ArtistColorBox" Visibility="Collapsed" Text="#C4C9D4" />

                        <StackPanel Orientation="Horizontal" Margin="0,12,0,0" Spacing="8">
                            <Button Content="保存" Click="SaveOverlaySettings_Click"
                                    Style="{ThemeResource AccentButtonStyle}" />
                            <Button Content="重置" Click="ResetOverlaySettings_Click" />
                            <Button Content="测试" Click="TestOverlay_Click" />
                        </StackPanel>
                    </StackPanel>
                </ScrollViewer>
            </Border>
        </Grid>

        <!-- Footer -->
        <Border Grid.Row="2" Margin="24,0,24,24" Padding="16,10" CornerRadius="8"
                Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" BorderThickness="1">
            <TextBlock Name="StatusText" FontSize="11" Opacity="0.6" Text="状态：空闲" />
        </Border>
    </Grid>
</Window>
