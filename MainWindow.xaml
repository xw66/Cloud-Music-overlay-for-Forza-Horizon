<Window x:Class="HorizonRadioOverlay.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="网易云悬浮窗"
        Height="720"
        Width="1200"
        MinHeight="720"
        MinWidth="1000"
        WindowStyle="None"
        ResizeMode="CanResizeWithGrip"
        WindowStartupLocation="CenterScreen"
        AllowsTransparency="True"
        Background="Transparent">
    <Window.Resources>
        <SolidColorBrush x:Key="AccentBrush" Color="#7C6BF0" />
        <SolidColorBrush x:Key="TextPrimary" Color="#FFFFFF" />
        <SolidColorBrush x:Key="TextSecondary" Color="#C4C9D4" />
        <SolidColorBrush x:Key="TextMuted" Color="#8D95A3" />
        <SolidColorBrush x:Key="GlassBg" Color="#1A1F2A" Opacity="0.78" />
        <SolidColorBrush x:Key="GlassBgSolid" Color="#181D28" />
        <SolidColorBrush x:Key="GlassBorder" Color="#30394A" Opacity="0.6" />
        <SolidColorBrush x:Key="InputBg" Color="#12161F" />
        <SolidColorBrush x:Key="InputBorder" Color="#2A3345" />
        <SolidColorBrush x:Key="CardBg" Color="#161B26" Opacity="0.88" />
        <SolidColorBrush x:Key="Divider" Color="#262E3E" />

        <Style TargetType="Button">
            <Setter Property="Foreground" Value="{StaticResource TextPrimary}" />
            <Setter Property="FontFamily" Value="Segoe UI" />
            <Setter Property="FontSize" Value="13" />
            <Setter Property="Padding" Value="16,8" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="border"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="10"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="border" Property="Background" Value="#2A3548" />
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="border" Property="Background" Value="#1A2230" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style TargetType="TextBox">
            <Setter Property="Background" Value="{StaticResource InputBg}" />
            <Setter Property="Foreground" Value="{StaticResource TextPrimary}" />
            <Setter Property="BorderBrush" Value="{StaticResource InputBorder}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="FontFamily" Value="Segoe UI" />
            <Setter Property="FontSize" Value="12" />
            <Setter Property="Padding" Value="8,5" />
            <Setter Property="CaretBrush" Value="{StaticResource AccentBrush}" />
        </Style>

        <Style TargetType="Slider">
            <Setter Property="Minimum" Value="0" />
            <Setter Property="Maximum" Value="100" />
            <Setter Property="Foreground" Value="{StaticResource AccentBrush}" />
        </Style>

        <Style TargetType="ComboBox">
            <Setter Property="Background" Value="{StaticResource InputBg}" />
            <Setter Property="Foreground" Value="{StaticResource TextPrimary}" />
            <Setter Property="BorderBrush" Value="{StaticResource InputBorder}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="FontFamily" Value="Segoe UI" />
            <Setter Property="FontSize" Value="12" />
            <Setter Property="Height" Value="32" />
        </Style>

        <Style TargetType="CheckBox">
            <Setter Property="Foreground" Value="{StaticResource TextSecondary}" />
            <Setter Property="FontFamily" Value="Segoe UI" />
            <Setter Property="FontSize" Value="12" />
        </Style>
    </Window.Resources>

    <Border x:Name="RootBorder" Background="#0C1018" CornerRadius="20" BorderThickness="1" BorderBrush="#262E3E">
        <Border.Effect>
            <DropShadowEffect BlurRadius="40" ShadowDepth="0" Opacity="0.3" Color="#000000" />
        </Border.Effect>

        <Grid Margin="24">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <!-- Header -->
            <Border Grid.Row="0" Padding="20,16" Background="{StaticResource GlassBg}" BorderThickness="1" BorderBrush="{StaticResource GlassBorder}" CornerRadius="16">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <StackPanel Grid.Column="0">
                        <TextBlock Text="网易云悬浮窗" FontSize="22" FontWeight="SemiBold" Foreground="{StaticResource TextPrimary}" />
                        <TextBlock Margin="0,4,0,0" FontSize="12" Foreground="{StaticResource TextSecondary}"
                                   Text="支持网易云窗口标题与 SMTC（QQ音乐/Apple Music 等）" />
                    </StackPanel>
                    <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                        <Button Width="90" Height="32" Background="{StaticResource GlassBgSolid}" BorderBrush="{StaticResource GlassBorder}" BorderThickness="1"
                                Click="CheckUpdate_Click">
                            <TextBlock Text="检查更新" FontSize="12" />
                        </Button>
                        <Button Width="36" Height="36" Margin="8,0,0,0" Padding="6"
                                Background="{StaticResource GlassBgSolid}" BorderBrush="{StaticResource GlassBorder}" BorderThickness="1"
                                Click="GitHubButton_Click">
                            <Image Name="GitHubImage" Stretch="Uniform" Width="18" Height="18" />
                        </Button>
                    </StackPanel>
                </Grid>
            </Border>

            <!-- Main Content -->
            <Grid Grid.Row="1" Margin="0,16,0,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="300" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>

                <!-- Left: Now Playing -->
                <Border Grid.Column="0" Padding="20" Background="{StaticResource CardBg}" BorderThickness="1" BorderBrush="{StaticResource GlassBorder}" CornerRadius="16">
                    <StackPanel>
                        <TextBlock FontSize="11" FontWeight="SemiBold" Foreground="{StaticResource TextMuted}" Text="正在播放" />
                        <Border Margin="0,12,0,0" Width="120" Height="120" CornerRadius="16" ClipToBounds="True"
                                HorizontalAlignment="Center" Background="#0E121A" BorderThickness="1" BorderBrush="{StaticResource InputBorder}">
                            <Image Name="CoverPreview" Stretch="UniformToFill" />
                        </Border>
                        <TextBlock Name="CurrentTitle" Margin="0,14,0,0" FontSize="18" FontWeight="SemiBold"
                                   Foreground="{StaticResource TextPrimary}" TextWrapping="Wrap" TextAlignment="Center"
                                   Text="未检测到播放中的歌曲" />
                        <TextBlock Name="CurrentArtist" Margin="0,6,0,0" FontSize="13"
                                   Foreground="{StaticResource TextSecondary}" TextAlignment="Center"
                                   Text="请先打开网易云音乐并播放" />
                        <TextBlock Name="CurrentMeta" Margin="0,4,0,0" FontSize="11"
                                   Foreground="{StaticResource TextMuted}" TextAlignment="Center" Text="来源：-" />

                        <Grid Margin="0,16,0,0">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <Button Grid.Column="0" Height="36" Margin="0,0,4,0"
                                    Background="{StaticResource GlassBgSolid}" BorderBrush="{StaticResource GlassBorder}" BorderThickness="1"
                                    Click="Prev_Click" Content="⏮" FontSize="14" />
                            <Button Grid.Column="1" Height="36" Margin="4,0,4,0"
                                    Background="{StaticResource GlassBgSolid}" BorderBrush="{StaticResource GlassBorder}" BorderThickness="1"
                                    Click="PlayPause_Click" Content="⏯" FontSize="14" />
                            <Button Grid.Column="2" Height="36" Margin="4,0,4,0"
                                    Background="{StaticResource GlassBgSolid}" BorderBrush="{StaticResource GlassBorder}" BorderThickness="1"
                                    Click="Next_Click" Content="⏭" FontSize="14" />
                            <Button Grid.Column="3" Height="36" Margin="4,0,0,0"
                                    Background="#1E1815" BorderBrush="#3A2E28" BorderThickness="1"
                                    Click="Refresh_Click" Content="⟳" FontSize="14" />
                        </Grid>
                    </StackPanel>
                </Border>

                <!-- Right: Settings -->
                <Border Grid.Column="1" Margin="16,0,0,0" Padding="20" Background="{StaticResource CardBg}" BorderThickness="1" BorderBrush="{StaticResource GlassBorder}" CornerRadius="16">
                    <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
                        <StackPanel>
                            <!-- Overlay -->
                            <TextBlock FontSize="11" FontWeight="SemiBold" Foreground="{StaticResource TextMuted}" Text="悬浮窗" />
                            <Grid Margin="0,10,0,0">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>
                                <StackPanel Grid.Column="0" Margin="0,0,10,0">
                                    <TextBlock FontSize="11" Foreground="{StaticResource TextSecondary}" Text="数据来源" />
                                    <ComboBox Name="TrackSourceComboBox" Margin="0,4,0,0" SelectedIndex="0"
                                              SelectionChanged="TrackSourceComboBox_SelectionChanged">
                                        <ComboBoxItem Tag="NeteaseProcess" Content="网易云窗口标题" />
                                        <ComboBoxItem Tag="SMTC" Content="QQ音乐 / Apple Music" />
                                    </ComboBox>
                                    <TextBlock Margin="0,4,0,0" FontSize="10" Foreground="{StaticResource TextMuted}"
                                               Text="漫游模式无封面" />
                                </StackPanel>
                                <StackPanel Grid.Column="1" Margin="5,0,5,0">
                                    <TextBlock FontSize="11" Foreground="{StaticResource TextSecondary}" Text="水平位置" />
                                    <Grid Margin="0,4,0,0">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="36" />
                                        </Grid.ColumnDefinitions>
                                        <Slider Name="HorizontalSlider" Grid.Column="0" Minimum="0" Maximum="40"
                                                ValueChanged="HorizontalSlider_ValueChanged" />
                                        <TextBlock Name="HorizontalValueText" Grid.Column="1" FontSize="11"
                                                   Foreground="{StaticResource TextMuted}"
                                                   VerticalAlignment="Center" TextAlignment="Right" Text="0%" />
                                    </Grid>
                                </StackPanel>
                                <StackPanel Grid.Column="2" Margin="10,0,0,0">
                                    <TextBlock FontSize="11" Foreground="{StaticResource TextSecondary}" Text="垂直位置" />
                                    <Grid Margin="0,4,0,0">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="36" />
                                        </Grid.ColumnDefinitions>
                                        <Slider Name="BottomOffsetSlider" Grid.Column="0" Minimum="0" Maximum="80"
                                                ValueChanged="BottomOffsetSlider_ValueChanged" />
                                        <TextBlock Name="BottomOffsetValueText" Grid.Column="1" FontSize="11"
                                                   Foreground="{StaticResource TextMuted}"
                                                   VerticalAlignment="Center" TextAlignment="Right" Text="0%" />
                                    </Grid>
                                </StackPanel>
                            </Grid>

                            <Grid Margin="0,8,0,0">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>
                                <StackPanel Grid.Column="0" Margin="0,0,10,0">
                                    <TextBlock FontSize="11" Foreground="{StaticResource TextSecondary}" Text="缩放" />
                                    <Grid Margin="0,4,0,0">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="36" />
                                        </Grid.ColumnDefinitions>
                                        <Slider Name="ScaleSlider" Grid.Column="0" Minimum="80" Maximum="180"
                                                ValueChanged="ScaleSlider_ValueChanged" />
                                        <TextBlock Name="ScaleValueText" Grid.Column="1" FontSize="11"
                                                   Foreground="{StaticResource TextMuted}"
                                                   VerticalAlignment="Center" TextAlignment="Right" Text="100%" />
                                    </Grid>
                                </StackPanel>
                                <StackPanel Grid.Column="1" Margin="5,0,5,0">
                                    <TextBlock FontSize="11" Foreground="{StaticResource TextSecondary}" Text="歌名颜色" />
                                    <TextBox Name="TitleColorBox" Margin="0,4,0,0" Height="30" Text="#FFFFFF" />
                                    <Grid Margin="0,4,0,0">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="36" />
                                        </Grid.ColumnDefinitions>
                                        <Slider Name="TitleOpacitySlider" Grid.Column="0" Minimum="0" Maximum="100" Value="100"
                                                ValueChanged="TitleOpacitySlider_ValueChanged" />
                                        <TextBlock Name="TitleOpacityValueText" Grid.Column="1" FontSize="11"
                                                   Foreground="{StaticResource TextMuted}"
                                                   VerticalAlignment="Center" TextAlignment="Right" Text="100%" />
                                    </Grid>
                                </StackPanel>
                                <StackPanel Grid.Column="2" Margin="10,0,0,0">
                                    <TextBlock FontSize="11" Foreground="{StaticResource TextSecondary}" Text="歌手颜色" />
                                    <TextBox Name="ArtistColorBox" Margin="0,4,0,0" Height="30" Text="#C4C9D4" />
                                    <Grid Margin="0,4,0,0">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="36" />
                                        </Grid.ColumnDefinitions>
                                        <Slider Name="ArtistOpacitySlider" Grid.Column="0" Minimum="0" Maximum="100" Value="100"
                                                ValueChanged="ArtistOpacitySlider_ValueChanged" />
                                        <TextBlock Name="ArtistOpacityValueText" Grid.Column="1" FontSize="11"
                                                   Foreground="{StaticResource TextMuted}"
                                                   VerticalAlignment="Center" TextAlignment="Right" Text="100%" />
                                    </Grid>
                                </StackPanel>
                            </Grid>

                            <Border Height="1" Background="{StaticResource Divider}" Margin="0,14,0,0" />

                            <!-- Hotkeys -->
                            <TextBlock FontSize="11" FontWeight="SemiBold" Foreground="{StaticResource TextMuted}" Text="快捷键映射" />
                            <TextBlock Margin="0,4,0,0" FontSize="11" Foreground="{StaticResource TextMuted}"
                                       Text="左侧：游戏内按键  |  右侧：转发给网易云的按键" />
                            <Grid Margin="0,10,0,0">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>
                                <StackPanel Grid.Column="0" Margin="0,0,8,0">
                                    <TextBlock FontSize="11" FontWeight="SemiBold" Foreground="{StaticResource TextSecondary}" Text="应用快捷键" />
                                    <TextBlock Margin="0,6,0,0" FontSize="11" Foreground="{StaticResource TextMuted}" Text="上一首" />
                                    <TextBox Name="AppPrevHotkeyBox" Margin="0,2,0,0" Height="30" Text="Ctrl+Shift+Left" />
                                    <TextBlock Margin="0,6,0,0" FontSize="11" Foreground="{StaticResource TextMuted}" Text="下一首" />
                                    <TextBox Name="AppNextHotkeyBox" Margin="0,2,0,0" Height="30" Text="Ctrl+Shift+Right" />
                                    <TextBlock Margin="0,6,0,0" FontSize="11" Foreground="{StaticResource TextMuted}" Text="播放/暂停" />
                                    <TextBox Name="AppToggleHotkeyBox" Margin="0,2,0,0" Height="30" Text="Ctrl+Shift+Down" />
                                </StackPanel>
                                <StackPanel Grid.Column="1" Margin="8,0,0,0">
                                    <TextBlock FontSize="11" FontWeight="SemiBold" Foreground="{StaticResource TextSecondary}" Text="网易云快捷键" />
                                    <TextBlock Margin="0,6,0,0" FontSize="11" Foreground="{StaticResource TextMuted}" Text="上一首" />
                                    <TextBox Name="NeteasePrevHotkeyBox" Margin="0,2,0,0" Height="30" Text="Ctrl+Alt+Left" />
                                    <TextBlock Margin="0,6,0,0" FontSize="11" Foreground="{StaticResource TextMuted}" Text="下一首" />
                                    <TextBox Name="NeteaseNextHotkeyBox" Margin="0,2,0,0" Height="30" Text="Ctrl+Alt+Right" />
                                    <TextBlock Margin="0,6,0,0" FontSize="11" Foreground="{StaticResource TextMuted}" Text="播放/暂停" />
                                    <TextBox Name="NeteaseToggleHotkeyBox" Margin="0,2,0,0" Height="30" Text="Ctrl+Alt+P" />
                                </StackPanel>
                            </Grid>

                            <Border Height="1" Background="{StaticResource Divider}" Margin="0,14,0,0" />

                            <!-- Gamepad -->
                            <TextBlock FontSize="11" FontWeight="SemiBold" Foreground="{StaticResource TextMuted}" Text="手柄快捷键" />
                            <CheckBox Name="EnableGamepadCheckBox" Margin="0,8,0,0" Content="启用 Xbox 手柄" />
                            <Grid Margin="0,8,0,0">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>
                                <StackPanel Grid.Column="0" Margin="0,0,8,0">
                                    <TextBlock FontSize="11" Foreground="{StaticResource TextMuted}" Text="上一首" />
                                    <TextBox Name="GamepadPrevHotkeyBox" Margin="0,2,0,0" Height="30" Text="LB+Left" />
                                </StackPanel>
                                <StackPanel Grid.Column="1" Margin="4,0,4,0">
                                    <TextBlock FontSize="11" Foreground="{StaticResource TextMuted}" Text="下一首" />
                                    <TextBox Name="GamepadNextHotkeyBox" Margin="0,2,0,0" Height="30" Text="RB+Right" />
                                </StackPanel>
                                <StackPanel Grid.Column="2" Margin="8,0,0,0">
                                    <TextBlock FontSize="11" Foreground="{StaticResource TextMuted}" Text="播放/暂停" />
                                    <TextBox Name="GamepadToggleHotkeyBox" Margin="0,2,0,0" Height="30" Text="LT+RT+Y" />
                                </StackPanel>
                            </Grid>

                            <Border Height="1" Background="{StaticResource Divider}" Margin="0,14,0,0" />

                            <!-- System -->
                            <TextBlock FontSize="11" FontWeight="SemiBold" Foreground="{StaticResource TextMuted}" Text="系统" />
                            <CheckBox Name="MinimizeToTrayCheckBox" Margin="0,8,0,0" Content="关闭窗口时最小化到系统托盘" IsChecked="True" />
                            <CheckBox Name="AutoStartCheckBox" Margin="0,6,0,0" Content="开机自启动" />

                            <!-- Actions -->
                            <StackPanel Orientation="Horizontal" Margin="0,16,0,0">
                                <Button Height="34" Padding="24,0" Background="#1E3028" BorderBrush="#2E5040" BorderThickness="1"
                                        Click="SaveOverlaySettings_Click">
                                    <TextBlock Text="保存" Foreground="#A0F0B0" />
                                </Button>
                                <Button Height="34" Margin="8,0,0,0" Padding="24,0"
                                        Background="{StaticResource GlassBgSolid}" BorderBrush="{StaticResource GlassBorder}" BorderThickness="1"
                                        Click="ResetOverlaySettings_Click">
                                    <TextBlock Text="重置" />
                                </Button>
                                <Button Height="34" Margin="8,0,0,0" Padding="24,0"
                                        Background="{StaticResource GlassBgSolid}" BorderBrush="{StaticResource GlassBorder}" BorderThickness="1"
                                        Click="TestOverlay_Click">
                                    <TextBlock Text="测试" />
                                </Button>
                            </StackPanel>
                        </StackPanel>
                    </ScrollViewer>
                </Border>
            </Grid>

            <!-- Footer -->
            <Border Grid.Row="2" Margin="0,16,0,0" Padding="16,10" Background="{StaticResource GlassBg}" BorderThickness="1" BorderBrush="{StaticResource GlassBorder}" CornerRadius="12">
                <TextBlock Name="StatusText" FontSize="11" Foreground="{StaticResource TextSecondary}" Text="状态：空闲" />
            </Border>
        </Grid>
    </Border>
</Window>
