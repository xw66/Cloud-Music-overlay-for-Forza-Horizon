<Window x:Class="HorizonRadioOverlay.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:HorizonRadioOverlay"
        xmlns:models="clr-namespace:HorizonRadioOverlay.Models"
        xmlns:pages="clr-namespace:HorizonRadioOverlay.Views.Pages"
        mc:Ignorable="d"
        Title="网易云悬浮窗"
        MinHeight="720"
        MinWidth="1180"
        Width="1380"
        Height="900"
        WindowStartupLocation="CenterScreen"
        ResizeMode="CanResizeWithGrip">
    <Grid Background="{StaticResource BackgroundBrush}">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="280" />
            <ColumnDefinition Width="*" />
        </Grid.ColumnDefinitions>

        <Border Grid.Column="0"
                Background="{StaticResource PrimaryDarkBrush}"
                BorderBrush="#2D3650"
                BorderThickness="0,0,1,0">
            <Grid Margin="20">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="24" />
                    <RowDefinition Height="*" />
                    <RowDefinition Height="24" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <StackPanel Grid.Row="0">
                    <StackPanel Orientation="Horizontal">
                        <Border x:Name="SidebarIconBadge"
                                Width="44"
                                Height="44"
                                CornerRadius="14"
                                Background="{StaticResource PrimaryBrush}">
                            <TextBlock VerticalAlignment="Center"
                                       HorizontalAlignment="Center"
                                       FontFamily="Segoe MDL2 Assets"
                                       FontSize="20"
                                       Foreground="White"
                                       Text="&#xE189;" />
                        </Border>
                        <StackPanel Margin="12,0,0,0"
                                    VerticalAlignment="Center">
                            <TextBlock FontSize="20"
                                       FontWeight="SemiBold"
                                       Foreground="White"
                                       Text="{x:Static local:UiText.AppTitle}" />
                            <TextBlock Margin="0,4,0,0"
                                       FontSize="12"
                                       Foreground="#A6B0C4"
                                       Text="{x:Static local:UiText.SmtcLyricsSupport}" />
                        </StackPanel>
                    </StackPanel>
                </StackPanel>

                <ListBox x:Name="NavigationListBox"
                         Grid.Row="2"
                         ItemsSource="{Binding NavigationItems}"
                         SelectedItem="{Binding SelectedItem, Mode=TwoWay}"
                         Background="Transparent"
                         BorderThickness="0"
                         SelectionChanged="NavigationListBox_SelectionChanged"
                         ScrollViewer.VerticalScrollBarVisibility="Disabled">
                    <ListBox.ItemContainerStyle>
                        <Style TargetType="ListBoxItem">
                            <Setter Property="Margin" Value="0,0,0,8" />
                            <Setter Property="Padding" Value="0" />
                            <Setter Property="HorizontalContentAlignment" Value="Stretch" />
                            <Setter Property="Template">
                                <Setter.Value>
                                    <ControlTemplate TargetType="ListBoxItem">
                                        <Border x:Name="ItemBorder"
                                                Padding="14,12"
                                                CornerRadius="14"
                                                Background="Transparent">
                                            <ContentPresenter />
                                        </Border>
                                        <ControlTemplate.Triggers>
                                            <Trigger Property="IsMouseOver" Value="True">
                                                <Setter TargetName="ItemBorder" Property="Background" Value="#27314A" />
                                            </Trigger>
                                            <Trigger Property="IsSelected" Value="True">
                                                <Setter TargetName="ItemBorder" Property="Background" Value="#5B5CEB" />
                                            </Trigger>
                                        </ControlTemplate.Triggers>
                                    </ControlTemplate>
                                </Setter.Value>
                            </Setter>
                        </Style>
                    </ListBox.ItemContainerStyle>
                    <ListBox.ItemTemplate>
                        <DataTemplate DataType="{x:Type models:NavigationItem}">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock FontFamily="Segoe MDL2 Assets"
                                           FontSize="16"
                                           Foreground="White"
                                           Text="{Binding IconGlyph}" />
                                <TextBlock Margin="12,0,0,0"
                                           VerticalAlignment="Center"
                                           FontSize="14"
                                           Foreground="White"
                                           Text="{Binding Title}" />
                            </StackPanel>
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                </ListBox>

                <Border Grid.Row="4"
                        Padding="16"
                        CornerRadius="18"
                        Background="#1A2338"
                        BorderBrush="#2E3852"
                        BorderThickness="1">
                    <StackPanel>
                        <StackPanel Orientation="Horizontal">
                            <Ellipse Width="10"
                                     Height="10"
                                     Fill="{StaticResource SuccessBrush}"
                                     VerticalAlignment="Center" />
                            <TextBlock x:Name="SidebarConnectionStateText"
                                       Margin="10,0,0,0"
                                       VerticalAlignment="Center"
                                       FontSize="14"
                                       Foreground="White"
                                       Text="{x:Static local:UiText.SidebarConnectedSmtc}" />
                        </StackPanel>
                        <TextBlock x:Name="SidebarConnectionSubText"
                                   Margin="20,6,0,0"
                                   FontSize="12"
                                   Foreground="#A6B0C4"
                                   Text="EosphorosVeil" />
                    </StackPanel>
                </Border>
            </Grid>
        </Border>

        <Grid Grid.Column="1">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <Border Grid.Row="0"
                    Background="{StaticResource SurfaceBrush}"
                    BorderBrush="{StaticResource BorderBrush}"
                    BorderThickness="0,0,0,1">
                <Grid Margin="28,20">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>

                    <StackPanel>
                        <TextBlock FontSize="30"
                                   FontWeight="SemiBold"
                                   Foreground="{StaticResource TextBrush}"
                                   Text="{Binding CurrentPageTitle}" />
                        <TextBlock Margin="0,6,0,0"
                                   FontSize="13"
                                   Foreground="{StaticResource SubtleTextBrush}"
                                   Text="{Binding CurrentPageDescription}" />
                    </StackPanel>

                    <StackPanel Grid.Column="1"
                                Orientation="Horizontal"
                                VerticalAlignment="Center">
                        <Button Width="102"
                                Height="40"
                                Margin="0,0,12,0"
                                Content="{x:Static local:UiText.CheckUpdate}"
                                Click="CheckUpdate_Click" />
                        <Button Width="102"
                                Height="40"
                                Margin="0,0,12,0"
                                Style="{StaticResource PrimaryButtonStyle}"
                                Content="{x:Static local:UiText.BaiduPan}"
                                Click="BaiduPanButton_Click" />
                        <Button Width="40"
                                Height="40"
                                Padding="8"
                                Click="GitHubButton_Click"
                                ToolTip="{x:Static local:UiText.ViewSourceCode}">
                            <Image x:Name="GitHubImage" Stretch="Uniform" />
                        </Button>
                    </StackPanel>
                </Grid>
            </Border>

            <Grid Grid.Row="1">
                <pages:NowPlayingPage x:Name="NowPlayingPageView" Visibility="Visible" />
                <pages:FloatingSettingsPage x:Name="FloatingSettingsPageView" Visibility="Collapsed" />
                <pages:HotkeySettingsPage x:Name="HotkeySettingsPageView" Visibility="Collapsed" />
                <pages:ThemeSettingsPage x:Name="ThemeSettingsPageView" Visibility="Collapsed" />
                <pages:LogsPage x:Name="LogsPageView" Visibility="Collapsed" />
                <pages:AboutPage x:Name="AboutPageView" Visibility="Collapsed" />
            </Grid>

            <Border Grid.Row="2"
                    Background="{StaticResource SurfaceBrush}"
                    BorderBrush="{StaticResource BorderBrush}"
                    BorderThickness="1,1,0,0">
                <Grid Margin="28,18">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>

                    <StackPanel>
                        <TextBlock x:Name="StatusText"
                                   FontSize="13"
                                   Foreground="{StaticResource TextBrush}"
                                   Text="{x:Static local:UiText.StatusIdle}" />
                        <TextBlock x:Name="FooterSourceText"
                                   Margin="0,6,0,0"
                                   FontSize="12"
                                   Foreground="{StaticResource SubtleTextBrush}"
                                   Text="{x:Static local:UiText.SourceUnknown}" />
                    </StackPanel>

                    <StackPanel Grid.Column="1"
                                Orientation="Horizontal"
                                VerticalAlignment="Center">
                        <Button x:Name="TestOverlayButton"
                                Width="96"
                                Height="40"
                                Margin="0,0,12,0"
                                Content="{x:Static local:UiText.TestPreview}"
                                Click="TestOverlay_Click" />
                        <Button x:Name="ResetSettingsButton"
                                Width="96"
                                Height="40"
                                Margin="0,0,12,0"
                                Content="{x:Static local:UiText.Reset}"
                                Click="ResetOverlaySettings_Click" />
                        <Button x:Name="SaveSettingsButton"
                                Width="112"
                                Height="40"
                                Style="{StaticResource PrimaryButtonStyle}"
                                Content="{x:Static local:UiText.SaveSettings}"
                                Click="SaveOverlaySettings_Click" />
                    </StackPanel>
                </Grid>
            </Border>
        </Grid>
    </Grid>
</Window>
